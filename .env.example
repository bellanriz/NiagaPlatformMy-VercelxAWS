# Database - Amazon Aurora PostgreSQL
DATABASE_URL=postgresql://username:password@your-aurora-cluster.cluster-xxxx.us-east-1.rds.amazonaws.com:5432/finflow

# NextAuth
NEXTAUTH_SECRET=your-super-secret-key-change-in-production-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=FinFlow
